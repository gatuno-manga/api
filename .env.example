# ===========================================
# Docker Compose Configuration
# ===========================================
# Para desenvolvimento: docker-compose.common.yml:docker-compose.dev.yml
# Para produção: docker-compose.common.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.common.yml:docker-compose.dev.yml

# ===========================================
# Application Environment
# ===========================================
# Valores: development, production, test
NODE_ENV=development

# Portas expostas (desenvolvimento)
API_PORT=3000

# ===========================================
# Hosts / URLs
# ===========================================
# Usados para configurar CORS e URLs internas
API_HOST=localhost:3000
ALLOWED_URL=http://localhost:4200
APP_URL=http://localhost:4200
API_URL=http://localhost:3000

# ===========================================
# Database Configuration (MySQL)
# ===========================================
DB_TYPE=mysql
DB_NAME=gatuno
DB_USER=gatuno
DB_PASS=your_secure_password
DB_PORT=3306
DB_MASTER_HOST=database-master
DB_SLAVE_HOSTS=database-slave-1,database-slave-2

# Portas externas para acesso direto ao banco (desenvolvimento)
DB_MASTER_EXTERNAL_PORT=3306
DB_SLAVE_1_EXTERNAL_PORT=3307
DB_SLAVE_2_EXTERNAL_PORT=3308

# Replicação MySQL
DB_REPL_USER=replicator
DB_REPL_PASS=replication_password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ===========================================
# Authentication & Security
# ===========================================
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=gatuno-auth
JWT_AUDIENCE=gatuno-api

# WebAuthn
WEBAUTHN_RP_NAME=Gatuno
WEBAUTHN_RP_ID=localhost

# MFA
MFA_ENCRYPTION_SECRET=change-this-mfa-secret-min-16-chars

# Initial Admin User
USERADMIN_EMAIL=admin@example.com
USERADMIN_PASSWORD=admin_password

# ===========================================
# Queue Concurrency
# ===========================================
CHAPTER_SCRAPING_CONCURRENCY=6
COVER_IMAGE_CONCURRENCY=3
FIX_CHAPTER_CONCURRENCY=2
BOOK_UPDATE_CONCURRENCY=2

# ===========================================
# Storage Configuration (RustFS / S3)
# ===========================================
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=gatuno-files
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_PUBLIC_ENDPOINT=http://localhost:9000
RUSTFS_REGION=us-east-1

# ===========================================
# Ferramentas de Desenvolvimento
# ===========================================
# PHPMyAdmin
PHPMYADMIN_PORT=8080

# Redis Commander
REDISCOMMANDER_PORT=8081

# Playwright Debug (noVNC - browser remoto)
PLAYWRIGHT_NOVNC_PORT=3001
PLAYWRIGHT_WS_ENDPOINT=ws://playwright-debug:3000
PLAYWRIGHT_DEBUG=false
