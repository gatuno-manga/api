# ===========================================
# Docker Compose Configuration
# ===========================================
# Para desenvolvimento: docker-compose.common.yml:docker-compose.dev.yml
# Para produção: docker-compose.common.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.common.yml:docker-compose.dev.yml

# ===========================================
# Application Environment
# ===========================================
# Valores: development, production, test
NODE_ENV=development

# Habilitar Swagger UI em qualquer ambiente (incluindo produção)
ENABLE_SWAGGER=false

# Portas expostas (desenvolvimento)
API_PORT=3000

# ===========================================
# Hosts / URLs
# ===========================================
# Usados para configurar CORS e URLs internas
API_HOST=localhost:3000
APP_HOST=localhost:4200
API_SCHEME=http
APP_SCHEME=http
ALLOWED_URL=http://localhost:4200

# ===========================================
# Database Configuration (MySQL)
# ===========================================
DB_TYPE=mysql
DB_NAME=gatuno
DB_USER=gatuno
DB_PASS=your_secure_password
DB_PORT=6033
DB_HOST=proxysql

# Portas externas para acesso direto ao banco (desenvolvimento)
DB_MASTER_EXTERNAL_PORT=3306
DB_SLAVE_1_EXTERNAL_PORT=3307
DB_SLAVE_2_EXTERNAL_PORT=3308

# Replicação MySQL
DB_REPL_USER=replicator
DB_REPL_PASS=replication_password

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ===========================================
# Authentication & Security
# ===========================================
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=gatuno-auth
JWT_AUDIENCE=gatuno-api

# WebAuthn
WEBAUTHN_RP_NAME=Gatuno
WEBAUTHN_RP_ID=localhost
ANDROID_SHA256_FINGERPRINTS=
ANDROID_PACKAGE_NAME=
# MFA
MFA_ENCRYPTION_SECRET=change-this-mfa-secret-min-16-chars

# Initial Admin User
USERADMIN_EMAIL=admin@example.com
USERADMIN_PASSWORD=admin_password

# ===========================================
# Queue Concurrency
# ===========================================
CHAPTER_SCRAPING_CONCURRENCY=6
COVER_IMAGE_CONCURRENCY=3
FIX_CHAPTER_CONCURRENCY=2
BOOK_UPDATE_CONCURRENCY=2

# ===========================================
# Storage Configuration (RustFS / S3)
# ===========================================
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=gatuno-files
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_PUBLIC_URL=http://localhost:9000
RUSTFS_REGION=us-east-1
RUSTFS_EXTRA_REFERERS=http://localhost:4200,http://localhost:3000
# Buckets que devem ter acesso público via Referer (separados por espaço)
RUSTFS_PUBLIC_BUCKETS="books users processing system"
# Exemplo de controle granular por bucket:
# RUSTFS_REFERERS_BOOKS=http://localhost:4200
# RUSTFS_REFERERS_USERS=http://localhost:4200,https://meu-perfil.com

# ===========================================
# Kafka Configuration
# ===========================================
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_PORT_EXTERNAL=9094

# ===========================================
# Ferramentas de Desenvolvimento
# ===========================================
# PHPMyAdmin
PHPMYADMIN_PORT=8080

# Redis Commander
REDISCOMMANDER_PORT=8081

# Playwright Debug (noVNC - browser remoto)
PLAYWRIGHT_NOVNC_PORT=3001
PLAYWRIGHT_WS_ENDPOINT=ws://browserless:3000
PLAYWRIGHT_DEBUG=false

# FlareSolverr
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_PORT=8191

# ===========================================
# NanoMQ Configuration (MQTT)
# ===========================================
NANOMQ_HOST=nanomq
NANOMQ_PORT=1883
NANOMQ_WS_PORT=8083

# ===========================================
# Search Engine (Meilisearch)
# ===========================================
MEILI_MASTER_KEY=your_meili_master_key
MEILI_HOST=http://meilisearch:7700

# ===========================================
# Logging & Observability
# ===========================================
# LOG_LEVEL define as regras de log por contexto.
# Sintaxe: context=NOME;level=NIVEL/context=*;level=NIVEL
# Níveis disponíveis: trace, debug, info, warn, error
# Simple Example: LOG_LEVEL=context=*;level=info
# Complex Example: LOG_LEVEL=context=AuthService,UsersController;level=debug/context=QueueModule;level=trace/context=*;level=info
LOG_LEVEL=context=*;level=info

# LOG_REDACT_PATHS: Lista de campos sensíveis para ocultar nos logs (JSON path)
# Padrão: req.headers.authorization,req.headers.cookie,req.body.password,req.body.apiKey,req.body.token,res.headers["set-cookie"]
LOG_REDACT_PATHS=req.headers.authorization,req.headers.cookie,req.body.password,req.body.apiKey,req.body.token,res.headers["set-cookie"]

# LOG_SAMPLING_RATE: Taxa de amostragem para logs de níveis info/debug/trace (0.0 a 1.0)
# 1.0 = 100% dos logs, 0.1 = 10% dos logs. Útil para reduzir volume em produção.
LOG_SAMPLING_RATE=1.0

# Métricas (Prometheus)
METRICS_ENABLED=true
METRICS_PATH=/api/metrics
METRICS_PREFIX=gatuno_

# Health Checks
HEALTH_HEAP_LIMIT_MB=300
HEALTH_RSS_LIMIT_MB=500
HEALTH_DISK_THRESHOLD_PERCENT=0.7
