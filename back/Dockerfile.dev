# ARG centraliza a versão — atualize apenas aqui ao fazer upgrade
ARG PLAYWRIGHT_VERSION=v1.49.1

# Usar imagem do Playwright que já tem os browsers e dependências
FROM mcr.microsoft.com/playwright:${PLAYWRIGHT_VERSION}-noble AS development

WORKDIR /usr/src/app

COPY package*.json ./
RUN npm ci

COPY . .

# Instalar apenas Chromium para desenvolvimento
RUN npx playwright install chromium

CMD ["npm", "run", "start:dev"]
