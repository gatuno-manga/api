{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testEnvironment": "node",
	"testRegex": ".e2e-spec.ts$",
	"silent": true,
	"setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"transformIgnorePatterns": ["node_modules/(?!(p-limit|yocto-queue)/)"],
	"moduleNameMapper": {
		"^src/(.*)$": "<rootDir>/../src/$1"
	}
}
